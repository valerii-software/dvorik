# ──────────── Django ────────────
# Generate one with: python -c 'import secrets; print(secrets.token_urlsafe(50))'
SECRET_KEY=change-me

DEBUG=0
ALLOWED_HOSTS=dvorik.example.com,localhost
# Comma-separated "scheme://host" list — required for HTTPS over nginx.
CSRF_TRUSTED_ORIGINS=https://dvorik.example.com

# ──────────── Postgres ────────────
POSTGRES_USER=dvorik
POSTGRES_PASSWORD=change-me-too
POSTGRES_DB=dvorik

# ──────────── Gunicorn ────────────
# Rule of thumb: workers = 2*CPU + 1, threads = 2-4 (gthread worker class).
GUNICORN_WORKERS=4
GUNICORN_THREADS=4

# ──────────── nginx ────────────
HTTP_PORT=80

# ──────────── Email (SMTP) ────────────
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=postmaster@dvorik.example.com
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
DEFAULT_FROM_EMAIL=Дворик <noreply@dvorik.example.com>

# ──────────── Sentry (optional) ────────────
# SENTRY_DSN=https://...@sentry.io/...
# SENTRY_TRACES=0.05

# ──────────── Local dev override ────────────
# Leave DATABASE_URL unset to use SQLite for local dev outside Docker.
# DATABASE_URL=postgres://dvorik:dvorik@localhost:5432/dvorik
# REDIS_URL=redis://localhost:6379/0
